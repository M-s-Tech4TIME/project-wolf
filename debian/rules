#!/usr/bin/make -f
# debian/rules — Wolf package build orchestration.
#
# Uses debhelper's `dh` sequencer. Each binary package (wolf-database,
# wolf-server, wolf-dashboard, wolf meta) gets its files via the
# debian/<package>.install + .postinst + .service conventions that
# slices 5.9-b/c/d will fill in.
#
# Current state (5.9-a): scaffold only. `dpkg-buildpackage -b`
# completes but produces empty .debs (no .install files yet).
# That's intentional — 5.9-a verifies the build infrastructure
# parses + dh runs without errors before per-component slices
# add their files.

%:
	# Modern debhelper (compat 13) invokes dh_installsystemd and
	# Python helpers natively. The legacy --with python3,systemd
	# addon syntax errors out in compat >= 11.
	dh $@

# Build hooks (placeholders — filled in by 5.9-b/c/d).
#
# 5.9-b will add an override_dh_auto_build for wolf-database
#   to create /usr/lib/wolf-database/.venv with the wolf-database
#   workspace package installed.
#
# 5.9-c will add similar for wolf-server (+ wolf-cert + wolf-common).
#
# 5.9-d will add an override that runs `npm run build` for
#   wolf-dashboard with output: "standalone" and copies the result
#   to debian/wolf-dashboard/usr/lib/wolf-dashboard/.

override_dh_auto_build:
	# ── wolf-database wheel (Phase 5.9-b) ────────────────────────
	# debian/wolf-database.install picks up the resulting whl from
	# packaging/build/ and ships it inside the .deb at
	# /usr/lib/wolf-database/. The postinst then creates the
	# venv at /usr/lib/wolf-database/.venv/ and pip-installs the
	# wheel into it — keeps the venv's absolute paths correct
	# regardless of where the .deb was built.
	mkdir -p packaging/build
	rm -f packaging/build/wolf_database-*.whl
	python3 -m pip wheel \
		--no-deps \
		--no-cache-dir \
		--wheel-dir packaging/build \
		packages/database/
	@echo "wolf-database wheel built: $$(ls packaging/build/wolf_database-*.whl)"

	# ── wolf-server wheel bundle (Phase 5.9-c) ───────────────────
	# Builds wolf-server + wolf-cert + the four workspace deps
	# (wolf-common, wolf-secrets, wolf-schema) AND every
	# transitive production dep (fastapi, sqlalchemy, asyncpg, ...).
	# All wheels land in packaging/build/wolf-server-wheels/;
	# debian/wolf-server.install ships them at
	# /usr/lib/wolf-server/wheels/. Postinst then runs
	# `pip install --no-index --find-links wheels/ wolf-server`
	# to resolve the entire graph from the bundle alone.
	mkdir -p packaging/build/wolf-server-wheels
	rm -rf packaging/build/wolf-server-wheels/*

	# Step 1 — build the workspace wheels separately (each
	# --no-deps to avoid pip trying to resolve wolf-common etc.
	# from PyPI where they don't exist). Order: leaf packages
	# first, then dependents.
	for pkg in packages/common packages/secrets packages/schema packages/cert ; do \
		python3 -m pip wheel \
			--no-deps \
			--no-cache-dir \
			--wheel-dir packaging/build/wolf-server-wheels \
			$$pkg ; \
	done

	# Step 2 — pip wheel for services/server with the workspace
	# wheels now on --find-links so pip can resolve wolf-common /
	# wolf-secrets / wolf-schema locally. This also downloads
	# every transitive production dep (fastapi + its deps,
	# sqlalchemy + asyncpg + greenlet, alembic + mako, etc.) into
	# the same dir.
	python3 -m pip wheel \
		--no-cache-dir \
		--find-links packaging/build/wolf-server-wheels \
		--wheel-dir packaging/build/wolf-server-wheels \
		services/server/

	@echo "wolf-server wheel bundle built: $$(ls packaging/build/wolf-server-wheels/*.whl | wc -l) wheels"

	# ── wolf-dashboard Next.js standalone build (Phase 5.9-d) ───
	# `npm ci` installs the lockfile-pinned deps deterministically.
	# `npm run build` then produces the standalone artifact at
	# services/dashboard/.next/standalone/ (server.js + a minimal
	# node_modules tree) because next.config.ts has
	# `output: "standalone"` set. debian/wolf-dashboard.install
	# picks up the standalone tree + .next/static/ + public/ and
	# ships them under /usr/lib/wolf-dashboard/ in the
	# conventional Next.js production layout.
	cd services/dashboard && npm ci --no-audit --no-fund
	cd services/dashboard && npm run build
	@echo "wolf-dashboard standalone build: $$(ls services/dashboard/.next/standalone/server.js && echo present)"

# Strip the upstream test suite from the built packages — Wolf's
# pytest suite shouldn't ship in /usr/lib/. dh_install rules in
# the per-component slices will list only the runtime files.
override_dh_auto_test:
	# We don't run the upstream pytest suite at build time. It's
	# already run in CI before any commit reaches main. Re-running
	# here would slow the build for no added safety.
	@echo "wolf packaging: skipping test phase (already gated by CI)"

override_dh_auto_install:
	# Wolf installs files via debian/<package>.install — NOT via
	# `make install`. Default dh_auto_install behaviour falls back
	# to invoking our project Makefile's `install` target (which
	# runs `uv sync` — not the right thing during a Debian build).
	# Override to no-op; debhelper's dh_install + dh_installsystemd
	# do the actual file placement from our debian/<package>.*
	# config files.
	@echo "wolf packaging: skipping dh_auto_install (files placed via debian/*.install)"
