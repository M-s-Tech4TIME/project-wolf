#!/bin/sh
# debian/wolf-dashboard.prerm — Phase 5.9-d.
# dh_installsystemd handles stop/disable via the DEBHELPER
# substitution point below. (NEVER write the literal token in a
# comment — debhelper substitutes it globally, breaking the
# installed script.)

set -e

case "$1" in
    remove|upgrade|deconfigure|failed-upgrade)
        ;;
    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
