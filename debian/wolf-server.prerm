#!/bin/sh
# debian/wolf-server.prerm — Phase 5.9-c.
# dh_installsystemd's snippet at the DEBHELPER substitution
# point handles the stop. (NEVER write the literal token in a
# comment — debhelper substitutes it globally, including in
# comments, which breaks the installed script.)

set -e

case "$1" in
    remove|upgrade|deconfigure|failed-upgrade)
        ;;
    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
