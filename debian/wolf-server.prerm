#!/bin/sh
# debian/wolf-server.prerm — Phase 5.9-c.
# dh_installsystemd's snippet at #DEBHELPER# handles the stop.

set -e

case "$1" in
    remove|upgrade|deconfigure|failed-upgrade)
        ;;
    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
