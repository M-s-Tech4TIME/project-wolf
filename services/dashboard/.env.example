# wolf-dashboard — environment template.
# Copy to .env.local (gitignored) and adjust.

# Server-side URL of wolf-server. wolf-dashboard's Next.js server reads
# this when reverse-proxying `/api/v1/...` requests (see
# `app/api/[...path]/route.ts`). The browser never sees this value —
# the browser only ever talks to wolf-dashboard's own origin.
#
# Phase 5.6-a (per ADR 0016) replaced the previous browser-side
# `NEXT_PUBLIC_SERVER_URL` env var with this server-side
# `WOLF_SERVER_URL`. Operators with the old name in their .env.local
# can delete it; the old name is no longer honored.
WOLF_SERVER_URL=http://localhost:7860
