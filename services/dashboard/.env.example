# wolf-dashboard — environment template.
# Copy to .env.local (gitignored) and adjust.

# URL of the wolf-server HTTP API. The dashboard talks to this with
# `credentials: "include"` so wolf-server's CORS config must allow
# this origin (localhost:3000 is allowed in development by default).
# Leave unset to let the dashboard's apiBase() helper derive the URL
# from window.location at request time — this is what makes the
# IP-agnostic dev posture (a3fdd73) work.
#
# Phase 5.5 rename: NEXT_PUBLIC_ORCHESTRATOR_URL → NEXT_PUBLIC_SERVER_URL.
# Operators with the old name in their .env.local should rename it.
NEXT_PUBLIC_SERVER_URL=http://localhost:7860
