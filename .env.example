# Wolf Orchestrator — environment template.
# Copy to .env and fill in.  .env is gitignored.

# ── Database ───────────────────────────────────────────────────────────────
# Production: Postgres 17 + pgvector.
# Dev/smoke test: a SQLite file under .local/ also works.
DATABASE_URL=postgresql+asyncpg://wolf:wolf_dev_password@localhost:5432/wolf
# DATABASE_URL=sqlite+aiosqlite:///./.local/wolf.db

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Auth ────────────────────────────────────────────────────────────────────
# Must be at least 32 characters.  Rotate to invalidate all existing sessions.
SECRET_KEY=change-me-this-must-be-at-least-32-chars

# ── Secrets backend ─────────────────────────────────────────────────────────
SECRETS_BACKEND=file
SECRETS_FILE_PATH=./.local/secrets.enc
# Generate: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_FILE_KEY=

# ── Model defaults (per-tenant overrides come in a later phase) ────────────
# Pick one: anthropic | openai | ollama
DEFAULT_MODEL_PROVIDER=ollama
DEFAULT_MODEL_ID=llama3.2

# For anthropic/openai, name the secret in the secrets backend holding the key.
# For ollama, leave empty.
DEFAULT_MODEL_API_KEY_REF=

OLLAMA_BASE_URL=http://localhost:11434
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
