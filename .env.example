# wolf-server — environment template.
# Copy to .env and fill in.  .env is gitignored.
# Phase 5.5 rename: this file used to be labelled "Wolf Orchestrator";
# the component is now "wolf-server" per ADR 0016.

# ── Database ───────────────────────────────────────────────────────────────
# Production: Postgres 17 + pgvector.
# Dev/smoke test: a SQLite file under .local/ also works.
DATABASE_URL=postgresql+asyncpg://wolf:wolf_dev_password@localhost:5432/wolf
# DATABASE_URL=sqlite+aiosqlite:///./.local/wolf.db

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Auth ────────────────────────────────────────────────────────────────────
# Must be at least 32 characters.  Rotate to invalidate all existing sessions.
SECRET_KEY=change-me-this-must-be-at-least-32-chars

# ── Secrets backend ─────────────────────────────────────────────────────────
SECRETS_BACKEND=file
SECRETS_FILE_PATH=./.local/secrets.enc
# Generate: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_FILE_KEY=

# ── Model defaults (per-tenant overrides come in a later phase) ────────────
# Pick one: anthropic | openai | ollama
DEFAULT_MODEL_PROVIDER=ollama
DEFAULT_MODEL_ID=llama3.2

# For anthropic/openai, name the secret in the secrets backend holding the key.
# For ollama, leave empty.
DEFAULT_MODEL_API_KEY_REF=

OLLAMA_BASE_URL=http://localhost:11434
OPENAI_BASE_URL=https://api.openai.com/v1

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for credentialed browser requests.
# Add the URL the analyst's browser uses to reach wolf-dashboard.  For a
# LAN deployment include the LAN IP origin as well as localhost.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Network bind + TLS (Phase 5.4-c) ───────────────────────────────────────
# The `python -m wolf_server` launcher picks HTTPS automatically when
# BOTH the TLS cert and key files exist at the configured paths;
# otherwise it falls back to plain HTTP. Run `wolf-cert init` to mint
# the pair — the launcher discovers them under
# `<repo>/.local/certs/server/` automatically (defaults are anchored
# at the project root via `Settings._PROJECT_ROOT`). Uncomment these
# only to point at an alternative location.
BIND_HOST=0.0.0.0
BIND_PORT=7860
#TLS_CERT_PATH=/etc/wolf-server/certs/cert.pem
#TLS_KEY_PATH=/etc/wolf-server/certs/key.pem

# ── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
