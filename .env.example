# wolf-server — environment template.
# Copy to .env and fill in.  .env is gitignored.
# Phase 5.5 rename: this file used to be labelled "Wolf Orchestrator";
# the component is now "wolf-server" per ADR 0016.

# ── Database ───────────────────────────────────────────────────────────────
# Two supported paths:
#
#   1. **wolf-database** (Phase 5.7, recommended) — Wolf manages the
#      Postgres cluster under .local/wolf-database/ (dev) or
#      /var/lib/wolf-database/ (prod). Run `make wolf-database-init`
#      once; the CLI prints a random password — paste it in place of
#      'GENERATED' below. Future `make wolf-database-up` /
#      `make wolf-database-down` lifecycle.
#
#   2. **System Postgres** (pre-5.7 path, still supported) — operator
#      installs postgresql-18 + postgresql-18-pgvector via apt/dnf
#      and creates the wolf role + db by hand. The DATABASE_URL is
#      identical in shape; only the password differs.
#
# Either path satisfies wolf-server. Pick one and uncomment its
# DATABASE_URL line.

# wolf-database (recommended) — replace GENERATED with the password
# from `make wolf-database-init`.
# DATABASE_URL=postgresql+asyncpg://wolf:GENERATED@localhost:5432/wolf

# System Postgres (pre-5.7 path).
DATABASE_URL=postgresql+asyncpg://wolf:wolf_dev_password@localhost:5432/wolf

# SQLite file under .local/ — works for unit tests; doesn't carry
# pgvector so won't work for the knowledge layer.
# DATABASE_URL=sqlite+aiosqlite:///./.local/wolf.db

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Auth ────────────────────────────────────────────────────────────────────
# Must be at least 32 characters.  Rotate to invalidate all existing sessions.
SECRET_KEY=change-me-this-must-be-at-least-32-chars

# Session-blacklist backend (Phase 6.5-g). Leave empty for the in-memory
# store (correct for the default single-process install). Set to an
# operator-managed Redis (e.g. redis://localhost:6379/0) for multi-worker
# installs or to make revocations survive wolf-server restarts.
#REDIS_URL=

# ── Secrets backend ─────────────────────────────────────────────────────────
SECRETS_BACKEND=file
SECRETS_FILE_PATH=./.local/secrets.enc
# Generate: uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_FILE_KEY=

# ── Model defaults (per-organization overrides come in a later phase) ────────────
# Pick one: anthropic | openai | ollama
DEFAULT_MODEL_PROVIDER=ollama
DEFAULT_MODEL_ID=llama3.2

# For anthropic/openai, name the secret in the secrets backend holding the key.
# For ollama, leave empty.
DEFAULT_MODEL_API_KEY_REF=

OLLAMA_BASE_URL=http://localhost:11434

# ── Performance & hardware tuning ────────────────────────────────────────────
# Speed <-> quality <-> context-capacity, bounded by GPU VRAM. FULL GUIDE
# (levers, trade-offs, when-to-use scenarios, apply/revert commands, benchmarks):
#   docs/reference/model-performance-tuning.md
#
# OLLAMA_NUM_CTX — context window for chat + judge (wolf-server side, this file).
# Ollama's built-in default is only 4096, which TRUNCATES Wolf's ~7.2K-token
# system-prompt + tool-catalog off the head -> the model answers "no such tool"
# with 0 tool calls. So the FLOOR is ~8192. Trade-off: larger context = larger
# KV-cache = more VRAM; on a small GPU that spills to CPU and slows generation
# (measured on a 6 GB card: 16384 = 14.4 tok/s / 55% GPU vs 4096 = 19.3 / 74%).
# 8192 = floor (thin headroom) · 12288 = safe · 16384 = generous (default).
OLLAMA_NUM_CTX=16384
#
# The following are set on the OLLAMA SERVICE (systemd drop-in), NOT this file —
# they are GLOBAL to the Ollama host (chat + judge). Listed here for discovery;
# see the tuning guide for exact apply/revert commands.
#   OLLAMA_FLASH_ATTENTION=1   -> enables KV-cache quantization (+ small win)
#   OLLAMA_KV_CACHE_TYPE=q8_0  -> half-size KV-cache, near-lossless (VRAM-tight:
#                                 keeps full context AND fits on-GPU); q4_0 =
#                                 quarter-size but real accuracy cost (avoid for
#                                 tool-calling/judge); f16 = full quality (default).
#   OLLAMA_NUM_PARALLEL=<N>    -> true concurrent chat+grounding (MSSP); unset on a
#                                 small GPU; >=2 on capable hardware (VRAM per slot).
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Embedding stack (knowledge retrieval; ADR 0012 / 0014) ──────────────────
# Default: nomic-embed-text via the Ollama daemon (native 768-dim — matches
# the pgvector column, no extra knobs). The column width is FIXED at 768;
# EMBEDDING_DIMENSION never changes without a migration + full re-embed.
#EMBEDDING_PROVIDER=ollama
#EMBEDDING_MODEL=nomic-embed-text
#
# qwen3-embedding recipe (verified live 2026-07-11). The model is MRL-trained
# (native 4096-dim, context 40960, instruction-aware retrieval): request
# server-side truncate+renormalize to 768 and prefix QUERIES with its official
# instruction (documents always embed raw). BOTH knobs are required.
# Switching the primary model needs a planned re-embed of existing chunks:
#   uv run python -m wolf_server.management.reembed --apply
#EMBEDDING_MODEL=qwen3-embedding:latest
#EMBEDDING_REQUEST_DIMENSIONS=768
#EMBEDDING_QUERY_PREFIX="Instruct: Given a web search query, retrieve relevant passages that answer the query\nQuery: "
#
# OR run it as the SECONDARY embedder (ADR 0014 3-leg RRF) and keep nomic
# primary — no primary re-embed; backfill v2 vectors with reembed --aux:
#EMBEDDING_MODEL_AUX=qwen3-embedding:latest
#EMBEDDING_REQUEST_DIMENSIONS_AUX=768
#EMBEDDING_QUERY_PREFIX_AUX="Instruct: Given a web search query, retrieve relevant passages that answer the query\nQuery: "
#
# VRAM: qwen3-embedding:latest is the 8B build (~4.7 GB) — on a 6 GB GPU it
# CANNOT be resident next to a qwen3:8b chat model; Ollama will swap models
# per request (slow chat<->search cycles). Small-GPU guidance: keep nomic
# (274 MB, always resident) or pull a smaller MRL variant (qwen3-embedding
# 0.6b/4b) before flipping. See docs/reference/model-performance-tuning.md.

# ── CORS ───────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for credentialed browser requests.
# Add the URL the analyst's browser uses to reach wolf-dashboard.  For a
# LAN deployment include the LAN IP origin as well as localhost.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Network bind + TLS (Phase 5.4-c) ───────────────────────────────────────
# The `python -m wolf_server` launcher picks HTTPS automatically when
# BOTH the TLS cert and key files exist at the configured paths;
# otherwise it falls back to plain HTTP. Run `wolf-cert init` to mint
# the pair — the launcher discovers them under
# `<repo>/.local/certs/server/` automatically (defaults are anchored
# at the project root via `Settings._PROJECT_ROOT`). Uncomment these
# only to point at an alternative location.
BIND_HOST=0.0.0.0
BIND_PORT=7860
#TLS_CERT_PATH=/etc/wolf-server/certs/cert.pem
#TLS_KEY_PATH=/etc/wolf-server/certs/key.pem

# ── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
