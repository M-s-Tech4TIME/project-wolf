# Build artifacts
dist/
build/

# Test / coverage
.coverage
.pytest_cache/
htmlcov/
*.egg-info/

# Secrets — never commit these
*.enc
*.pem
*.key
.env.*
!.env.example

# Docker volumes
postgres_data/

# Local dev state (SQLite files, scratch secrets blob, etc.)
.local/

# Operator-supplied credential drop (per-machine; never committed)
credentials/

# Slice 3 seed downloads — cached ATT&CK + Wazuh ruleset archives
.local/seed_knowledge_cache/

# IDE
.idea/
.vscode/
*.swp

# graphify output is local-only (operator decision 2026-06-16): the whole
# graphify-out/ tree is excluded from git. The post-commit graphify hook
# still regenerates the graph locally on every commit, so each working copy
# keeps a current knowledge graph — it's just no longer committed (was
# previously tracked; reversed to stop graph churn polluting commits/diffs).
graphify-out/
