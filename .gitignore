# Python
__pycache__/
*.py[cod]
*.pyo
.venv/
.env
*.egg-info/

# uv
uv.lock.bak

# Node
node_modules/
.next/
.pnpm-store/

# Build artifacts
dist/
build/

# Test / coverage
.coverage
.pytest_cache/
htmlcov/
*.egg-info/

# Secrets — never commit these
*.enc
*.pem
*.key
.env.*
!.env.example

# Docker volumes
postgres_data/

# Local dev state (SQLite files, scratch secrets blob, etc.)
.local/

# Operator-supplied credential drop (per-machine; never committed)
credentials/

# Slice 3 seed downloads — cached ATT&CK + Wazuh ruleset archives
.local/seed_knowledge_cache/

# IDE
.idea/
.vscode/
*.swp

# graphify outputs are INTENTIONALLY committed so Claude Code sessions
# (and other developers) start with a current knowledge graph of the
# project. The post-commit `graphify hook install` regenerates the
# graph automatically, keeping graphify-out/ in sync without manual
# intervention. Only the per-developer interpreter pointer files are
# excluded (they hardcode local paths):
graphify-out/.graphify_python
graphify-out/.graphify_root
